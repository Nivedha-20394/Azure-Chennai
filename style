body {
  font-family: 'Segoe UI', Arial, sans-serif;
  margin: 0;
  padding: 0;
  background: #eef6f9;
  color: #333;
}

header {
  background: #004466;
  color: #fff;
  text-align: center;
  padding: 20px;
}

nav a {
  color: #fff;
  margin: 0 15px;
  text-decoration: none;
  font-weight: bold;
}

.hero {
  width: 100%;
  height: auto;
  border-radius: 8px;
}

main {
  padding: 20px;
}

footer {
  background: #004466;
  color: #fff;
  text-align: center;
  padding: 15px;
}
